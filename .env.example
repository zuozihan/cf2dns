# Cloudflare 优选源 key（可选，当前网页抓取模式下不强依赖）
KEY=o1zrmHAF

# DNS 配置：1=DNSPod, 2=阿里云, 3=华为云
DNS_SERVER=2
SECRETID=your-secret-id
SECRETKEY=your-secret-key

# 仅阿里云生效
REGION_ALI=cn-hongkong

# 仅华为云生效
REGION_HW=cn-east-3

# 通用运行参数
AFFECT_NUM=2
TTL=600
TYPE=v4
# 轮询执行间隔（秒），默认 900 秒（15 分钟）
INTERVAL_SECONDS=900
LOG_FILE=cf2dns.log

# 必须是 JSON 字符串
# CM:移动 CU:联通 CT:电信 AB:境外 DEF:默认
DOMAINS={"example.com":{"@":["CM","CU","CT"]}}
